# Database (use Vercel Postgres, Neon, or Supabase for production)
DATABASE_URL="postgresql://user:password@localhost:5432/neuroid"

# Auth — generate with: npx auth secret
AUTH_SECRET="your-auth-secret-here"
# Set AUTH_URL only for local dev. Vercel auto-detects in production.
AUTH_URL="http://localhost:3000"

# AWS S3 — for asset storage
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="neuroid-assets"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
